{
	"appId": "tj.safeddara.app",
	"appName": "Safeddara",
	"webDir": "dist",
	"backgroundColor": "#ffffff",
	"android": {
		"allowMixedContent": true,
		"appendUserAgent": "SafeddaraNative/1.0",
		"adjustMarginsForEdgeToEdge": "auto"
	},
	"ios": {
		"contentInset": "never",
		"allowsLinkPreview": false,
		"preferredContentMode": "mobile",
		"scrollEnabled": true
	},
	"plugins": {
		"CapacitorHttp": {
			"enabled": true
		}
	},
	"packageClassList": [
		"AppPlugin",
		"CAPBrowserPlugin",
		"DevicePlugin"
	]
}
